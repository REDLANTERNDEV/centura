{
  "name": "centura",
  "type": "module",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace centura-be",
    "dev:frontend": "npm run dev --workspace centura-fe",
    "sync:bruno": "node scripts/sync-bruno-env.js",
    "format": "prettier --write .",
    "lint": "eslint .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@typescript-eslint/eslint-plugin": "^8.53.1",
    "@typescript-eslint/parser": "^8.53.1",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.53.1"
  },
  "overrides": {
    "@babel/core": "7.29.7",
    "form-data": "4.0.6",
    "ip-address": "^10.2.0",
    "js-yaml": "4.2.0",
    "lodash": "^4.18.0",
    "postcss": "8.5.10",
    "qs": "6.15.2",
    "body-parser": {
      "qs": "6.15.2"
    },
    "express": {
      "qs": "6.15.2"
    },
    "next": {
      ".": "16.2.6",
      "postcss": "8.5.10"
    }
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
